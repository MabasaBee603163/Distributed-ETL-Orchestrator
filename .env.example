LOG_LEVEL=INFO

# Copy this file to `.env` in the SAME folder as `main.py`.
# Supported filenames loaded automatically: `.env`, `.env.env`, `.env.local`.

# Input / Flow config
CSV_PATH=data/input.csv
CSV_S3_BUCKET=
CSV_S3_KEY=
SUPABASE_TABLE=contacts
REQUIRED_COLUMNS=
UPSERT=true

# Supabase (use service_role for server-side ETL; rotate any key pasted into chat repos)
SUPABASE_URL=
SUPABASE_KEY=

# Postgres connection URI (from Supabase → Project Settings → Database)
# Used only if you want profiling to EXECUTE generated CREATE TABLE SQL automatically.
SUPABASE_DB_URL=

# GUI behavior
# Set to true to restore old behavior: `python main.py` runs CSV→Supabase without opening Tk UI.
ETL_NO_GUI=false

# Prefect worker / deployments (Docker + AWS)
# Point this at Prefect Cloud or your self-hosted Prefect API.
PREFECT_API_URL=
# Prefect Cloud API key (if applicable)
PREFECT_API_KEY=
# Work pool your deployments target
PREFECT_WORK_POOL=ETL
# Usually `process` for this repo’s flows executed inside the worker container
PREFECT_WORKER_TYPE=process
# Optional: space-separated queue names
PREFECT_WORK_QUEUES=
PREFECT_WORKER_CONCURRENCY_LIMIT=

# API → Supabase (`python main.py run-api`)
API_URL=
API_METHOD=GET
API_HEADERS_JSON=
API_PARAMS_JSON=
API_JSON_BODY_JSON=
API_TIMEOUT_S=30

# Optional: AWS Secrets Manager (only needed if you intentionally fetch secrets from AWS)
# USE_AWS_SECRETS=false
AWS_REGION=us-east-1
